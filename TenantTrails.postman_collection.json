          }
        },

        {
          "name": "POST /upload – with image (manual test)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Returns a url', () => pm.expect(pm.response.json()).to.have.property('url'));",
                  "pm.test('URL is a string', () => pm.expect(pm.response.json().url).to.be.a('string'));",
                  "pm.test('URL starts with https', () => pm.expect(pm.response.json().url).to.match(/^https/));"
