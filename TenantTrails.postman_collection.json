    {
      "name": "Upload",
      "item": [
        {
          "name": "POST /upload – no auth (should 401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401 without token', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base}}/upload",
            "body": {
              "mode": "formdata",
              "formdata": []
