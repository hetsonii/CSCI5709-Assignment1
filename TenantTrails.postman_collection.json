    {
      "name": "Apartments",
      "item": [
        {
          "name": "GET /apartments",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 ok', () => pm.response.to.have.status(200));",
                  "pm.test('apartments is array', () => pm.expect(pm.response.json().apartments).to.be.an('array'));",
                  "pm.test('fields are aliased (avgRating)', () => pm.expect(pm.response.json().apartments[0]).to.have.property('avgRating'));",
                  "pm.test('fields are aliased (reviewCount)', () => pm.expect(pm.response.json().apartments[0]).to.have.property('reviewCount'));",
                  "pm.test('fields are aliased (yearBuilt)', () => pm.expect(pm.response.json().apartments[0]).to.have.property('yearBuilt'));",
                  "pm.test('old snake_case fields absent', () => {",
                  "  const a = pm.response.json().apartments[0];",
                  "  pm.expect(a).not.to.have.property('avg_rating');",
                  "  pm.expect(a).not.to.have.property('review_count');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base}}/apartments"
          }
        },
        {
          "name": "GET /apartments/:slug",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 ok', () => pm.response.to.have.status(200));",
                  "pm.test('apartment.avgRating aliased', () => pm.expect(pm.response.json().apartment).to.have.property('avgRating'));",
                  "pm.test('reviews is array', () => pm.expect(pm.response.json().reviews).to.be.an('array'));",
                  "pm.test('review fields aliased (id, text, imageUrl)', () => {",
                  "  if (pm.response.json().reviews.length > 0) {",
                  "    const r = pm.response.json().reviews[0];",
                  "    pm.expect(r).to.have.property('id');",
                  "    pm.expect(r).to.have.property('text');",
                  "    pm.expect(r).to.have.property('imageUrl');",
                  "    pm.expect(r).to.have.property('createdAt');",
                  "    pm.expect(r).not.to.have.property('body');",
                  "    pm.expect(r).not.to.have.property('image_url');",
                  "  }",
                  "});",
                  "pm.test('ratingBreakdown present', () => pm.expect(pm.response.json()).to.have.property('ratingBreakdown'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base}}/apartments/le-marchant-towers"
          }
